# Flask Environment Configuration
FLASK_ENV=development
PORT=5000

# SQLAlchemy Database URL (Update with your actual connection string)
# PostgreSQL format (Render): postgresql://username:password@host:port/database
# SQLAlchemy/psycopg explicit format: postgresql+psycopg://username:password@host:port/database
# Local PostgreSQL example: postgresql+psycopg://postgres:password@localhost:5432/macmind
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/macmind

# Flask Secret Keys (Change these in production!)
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# Email Configuration (for OTP and notifications)
EMAIL_USER=medapp53@gmail.com
EMAIL_PASS=umgs pllq igin qtuk

# CORS Configuration (comma-separated list of allowed origins)
# For development: allow all ('*')
# For production: specify exact origins (e.g., 'https://yourdomain.com,https://app.yourdomain.com')
CORS_ORIGINS=*
